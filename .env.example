# ── Keystatic CMS ──────────────────────────────────────────────────
# Option A: GitHub OAuth (production / Vercel)
# Create a GitHub OAuth App → https://github.com/settings/developers
#   Homepage URL:  https://your-domain.com
#   Callback URL:  https://your-domain.com/api/keystatic/github/oauth/callback
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=          # any random 32+ char string (e.g. openssl rand -hex 32)

# Option B: HTTP Basic Auth fallback (simple, single-user)
# KEYSTATIC_ADMIN_USER=admin
# KEYSTATIC_ADMIN_PASSWORD=change-me

# GitHub repo (defaults are baked into keystatic.config.ts)
# NEXT_PUBLIC_KEYSTATIC_GITHUB_OWNER=zamadshakil
# NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=al-barak-landing-page

# Storage mode: set to "github" on the Vercel project that has
# the GitHub OAuth secrets above. Leave unset for local dev.
# NEXT_PUBLIC_KEYSTATIC_STORAGE_KIND=github
